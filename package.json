{
  "name": "@lovelace_lol/latticework",
  "version": "0.0.2",
  "description": "Standalone character runtime agencies extracted from LoomLarge",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@lovelace_lol/loom3": "^1.0.30",
    "effect": "^3.19.14",
    "most-subject": "^6.0.0",
    "rxjs": "^7.8.2",
    "xstate": "^5.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "three": ">=0.170.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "keywords": [
    "animation",
    "avatar",
    "character-animation",
    "conversation",
    "gaze",
    "lip-sync",
    "prosody",
    "tts",
    "xstate"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meekmachine/Latticework.git"
  },
  "bugs": {
    "url": "https://github.com/meekmachine/Latticework/issues"
  },
  "homepage": "https://github.com/meekmachine/Latticework#readme",
  "author": "Jonathan",
  "license": "MIT",
  "packageManager": "npm@10.9.2"
}
